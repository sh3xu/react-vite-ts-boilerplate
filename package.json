{
  "name": "create-nodejs-express-app",
  "version": "1.7.0",
  "description": "Create a Node.js app for building production-ready RESTful APIs using Express, by running one command",
  "packageManager": "pnpm@10.26.1",
  "bin": "bin/createNodejsApp.js",
  "main": "src/index.js",
  "repository": "https://github.com/sh3xu/react-vite-ts-boilerplate.git",
  "author": "sh3xu",
  "license": "MIT",
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.json --no-daemon",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "seed:admin": "cross-env NODE_ENV=development node src/seeders/admin.seeder.js",
    "test": "cross-env NODE_ENV=test jest -i --colors --verbose --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest -i --watchAll",
    "coverage": "cross-env NODE_ENV=test jest -i --coverage",
    "coverage:coveralls": "cross-env NODE_ENV=test jest -i --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "frontend:dev": "pnpm --dir=frontend dev",
    "frontend:build": "pnpm --dir=frontend build",
    "frontend:lint": "pnpm --dir=frontend lint",
    "frontend:lint:fix": "pnpm --dir=frontend lint:fix",
    "frontend:preview": "pnpm --dir=frontend preview",
    "frontend:storybook": "pnpm --dir=frontend storybook",
    "frontend:build-storybook": "pnpm --dir=frontend build-storybook",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "bin/**/*.{js,cjs,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "src/**/*.{js,cjs,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "frontend/**/*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm --dir=frontend biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "jest",
    "travis",
    "docker",
    "passport",
    "joi",
    "biome"
  ],
  "dependencies": {
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "hbs": "^4.2.0",
    "helmet": "^8.1.0",
    "http-status": "^1.8.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "qrcode": "^1.5.4",
    "react-hook-form": "^7.71.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "coveralls": "^3.1.1",
    "cross-env": "^10.1.0",
    "husky": "9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
